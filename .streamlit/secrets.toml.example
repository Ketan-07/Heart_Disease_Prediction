# Copy this file to .streamlit/secrets.toml for LOCAL development.
# NEVER commit the real secrets.toml file to GitHub — it is already
# excluded via .gitignore.
#
# For Streamlit Cloud deployment, do NOT upload this file. Instead, paste
# the same content into your app's "Secrets" settings in the Streamlit
# Cloud dashboard (see README.md for exact steps).

GEMINI_API_KEY = "your-gemini-api-key-here"
